<aside class="w-64 bg-white border-r border-stone-200 flex flex-col shrink-0">
  <div class="px-5 py-5 border-b border-stone-100">
    <%= link_to root_path, class: "flex items-center gap-3" do %>
      <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0">
        <svg class="w-4.5 h-4.5 text-white" viewBox="0 0 20 20" fill="currentColor" style="width:18px;height:18px">
          <path d="M13 6a3 3 0 11-6 0 3 3 0 016 0zM18 8a2 2 0 11-4 0 2 2 0 014 0zM14 15a4 4 0 00-8 0v1h8v-1zM6 8a2 2 0 11-4 0 2 2 0 014 0zM16 18v-1a5.972 5.972 0 00-.75-2.906A3.005 3.005 0 0119 15v1h-3zM4.75 14.094A5.973 5.973 0 004 17v1H1v-1a3 3 0 013.75-2.906z"/>
        </svg>
      </div>
      <div>
        <div class="text-sm font-semibold text-stone-900 leading-none">Flowt</div>
        <div class="text-[11px] text-stone-400 mt-0.5">HR analytics</div>
      </div>
    <% end %>
  </div>

  <nav class="px-3 pt-4 pb-2 space-y-0.5">
    <%= link_to root_path, class: "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors #{current_page?(root_path) ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-stone-600 hover:bg-stone-50 hover:text-stone-900'}" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
      Overview
    <% end %>
    <%= link_to datasets_path, class: "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'datasets' ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-stone-600 hover:bg-stone-50 hover:text-stone-900'}" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7M4 7c0-2 1-3 3-3h10c2 0 3 1 3 3M4 7h16M9 11h6M9 15h4"/></svg>
      Datasets
    <% end %>
    <%= link_to comparison_path, class: "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors #{current_page?(comparison_path) ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-stone-600 hover:bg-stone-50 hover:text-stone-900'}" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      Comparison
    <% end %>
    <%= link_to import_jobs_path, class: "flex items-center gap-2.5 px-3 py-2 rounded-lg text-sm transition-colors #{controller_name == 'import_jobs' ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-stone-600 hover:bg-stone-50 hover:text-stone-900'}" do %>
      <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.75"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
      Jobs
    <% end %>
  </nav>

  <div class="px-5 mt-4 mb-2 flex items-center gap-2">
    <span class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Departments</span>
    <div class="flex-1 h-px bg-stone-100"></div>
  </div>

  <div class="px-3 pb-6 space-y-0.5 overflow-y-auto flex-1">
    <% if @sidebar_departments.blank? %>
      <div class="text-xs text-stone-400 px-3 py-3 leading-relaxed">No departments yet. Upload a dataset to get started.</div>
    <% end %>
    <% (@sidebar_departments || []).each do |dept| %>
      <%
        profile = dept.department_profile
        engagement = profile&.snapshot_data&.dig("engagement", "average")
        active = controller_name == "departments" && @department&.id == dept.id
        score = engagement ? engagement.round(1) : nil
        score_color = if score.nil? then ""
          elsif score >= 4.0 then "text-emerald-600"
          elsif score >= 3.0 then "text-amber-600"
          else "text-rose-600"
          end
      %>
      <%= link_to department_path(dept), class: "flex items-center gap-2.5 px-3 py-2.5 rounded-lg transition-colors #{active ? 'bg-indigo-50' : 'hover:bg-stone-50'}" do %>
        <div class="w-6 h-6 rounded-md bg-stone-100 flex items-center justify-center shrink-0 text-[11px] font-semibold text-stone-500">
          <%= dept.name[0].upcase %>
        </div>
        <div class="flex-1 min-w-0">
          <div class="text-sm <%= active ? 'text-indigo-700 font-medium' : 'text-stone-700' %> truncate leading-none"><%= dept.name %></div>
          <div class="text-[11px] text-stone-400 mt-0.5"><%= pluralize(dept.relevant_datasets.count, "dataset") %></div>
        </div>
        <% if score %>
          <span class="text-xs font-medium tabular-nums <%= score_color %>"><%= score %></span>
        <% end %>
      <% end %>
    <% end %>
  </div>
</aside>
