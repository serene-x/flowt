<% events = snapshot["events"] || {} %>

<% if events.empty? %>
  <%= render "empty_section", message: "No events dataset linked yet." %>
<% else %>
  <div class="grid grid-cols-3 gap-4 mb-7">
    <div class="bg-white rounded-xl border border-stone-200 px-5 py-4 shadow-sm">
      <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-1">Avg attendance</div>
      <div class="text-3xl font-bold tabular-nums text-stone-900"><%= format_percent(events["attendance_rate"]) %></div>
    </div>
    <div class="bg-white rounded-xl border border-stone-200 px-5 py-4 shadow-sm">
      <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-1">Events tracked</div>
      <div class="text-3xl font-bold tabular-nums text-stone-900"><%= events["events"] || 0 %></div>
    </div>
    <div class="bg-white rounded-xl border border-stone-200 px-5 py-4 shadow-sm">
      <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-1">Best format</div>
      <div class="text-xl font-bold text-indigo-700 mt-1 capitalize"><%= events["by_format"]&.max_by { |_, v| v.to_f }&.first || "—" %></div>
    </div>
  </div>

  <% trend = events["by_date"] || {} %>
  <% if trend.any? %>
    <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden mb-5">
      <div class="px-6 py-4 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-stone-800">Attendance over time</h2>
      </div>
      <div class="px-6 py-5" data-controller="line-chart" data-line-chart-data-value="<%= trend.transform_values { |v| (v.to_f * 100).round(1) }.to_json %>">
        <canvas height="200" class="w-full"></canvas>
      </div>
    </section>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <% formats = events["by_format"] || {} %>
    <% if formats.any? %>
      <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-stone-100">
          <h2 class="text-sm font-semibold text-stone-800">Attendance by format</h2>
        </div>
        <div class="px-6 py-5" data-controller="bar-chart"
             data-bar-chart-data-value="<%= formats.map { |k, v| { range: k, count: ((v || 0) * 100).round(1) } }.to_json %>"
             data-bar-chart-orientation-value="horizontal">
          <canvas height="<%= [formats.size * 30 + 40, 160].max %>" class="w-full"></canvas>
        </div>
      </section>
    <% end %>

    <% top_events = events["top_events"] || [] %>
    <% if top_events.any? %>
      <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-stone-100">
          <h2 class="text-sm font-semibold text-stone-800">Top events by attendance</h2>
        </div>
        <div class="px-6 py-5" data-controller="bar-chart"
             data-bar-chart-data-value="<%= top_events.map { |e| { range: e['name'].to_s.truncate(30), count: ((e['rate'] || 0) * 100).round(1) } }.to_json %>"
             data-bar-chart-orientation-value="horizontal">
          <canvas height="<%= [top_events.size * 26 + 40, 160].max %>" class="w-full"></canvas>
        </div>
      </section>
    <% end %>
  </div>
<% end %>
