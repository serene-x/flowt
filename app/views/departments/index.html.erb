<% page_title = "Departments" %>

<div class="mb-7">
  <h1 class="text-xl font-bold text-stone-900">Departments</h1>
  <p class="text-sm text-stone-500 mt-0.5"><%= pluralize(@departments.size, "department") %> with data</p>
</div>

<% if @departments.empty? %>
  <div class="bg-white rounded-xl border border-stone-200 p-12 text-center shadow-sm">
    <div class="w-14 h-14 rounded-2xl bg-stone-50 flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    </div>
    <h2 class="text-base font-semibold text-stone-900">No departments yet</h2>
    <p class="text-sm text-stone-500 mt-1.5 max-w-xs mx-auto">Upload a CSV that includes a department column and they'll appear here automatically.</p>
    <%= link_to "Upload a dataset", new_dataset_path, class: "inline-flex items-center gap-2 mt-5 px-4 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors shadow-sm" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
    <% @departments.each do |dept| %>
      <% snapshot = dept.department_profile&.snapshot_data || {} %>
      <% engagement = snapshot.dig("engagement", "average") %>
      <% turnover = snapshot.dig("turnover", "rate") %>
      <% headcount = snapshot.dig("headcount", "total") %>
      <%= link_to department_path(dept), class: "block bg-white border border-stone-200 rounded-xl p-5 hover:border-indigo-200 hover:shadow-md transition-all group" do %>
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-xl bg-indigo-50 flex items-center justify-center text-indigo-700 font-bold text-lg shrink-0">
            <%= dept.name[0].upcase %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-stone-900 group-hover:text-indigo-700 transition-colors truncate"><%= dept.name %></div>
            <div class="text-xs text-stone-400 mt-0.5"><%= pluralize(dept.relevant_datasets.count, "dataset") %></div>
          </div>
          <svg class="w-4 h-4 text-stone-300 group-hover:text-indigo-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
        </div>
        <div class="grid grid-cols-3 gap-2">
          <div class="bg-stone-50 rounded-lg px-3 py-2.5">
            <div class="text-[10px] uppercase tracking-widest font-semibold text-stone-400 mb-0.5">Headcount</div>
            <div class="text-sm font-bold tabular-nums text-stone-900"><%= headcount || "—" %></div>
          </div>
          <div class="bg-stone-50 rounded-lg px-3 py-2.5">
            <div class="text-[10px] uppercase tracking-widest font-semibold text-stone-400 mb-0.5">Engagement</div>
            <% eng_color = engagement ? (engagement >= 4 ? 'text-emerald-700' : engagement >= 3 ? 'text-amber-700' : 'text-rose-700') : 'text-stone-900' %>
            <div class="text-sm font-bold tabular-nums <%= eng_color %>"><%= engagement&.round(2) || "—" %></div>
          </div>
          <div class="bg-stone-50 rounded-lg px-3 py-2.5">
            <div class="text-[10px] uppercase tracking-widest font-semibold text-stone-400 mb-0.5">Turnover</div>
            <div class="text-sm font-bold tabular-nums text-stone-900"><%= format_percent(turnover) %></div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
