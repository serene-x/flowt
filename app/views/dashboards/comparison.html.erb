<% page_title = "Comparison" %>

<div class="mb-7">
  <h1 class="text-xl font-bold text-stone-900">Department comparison</h1>
  <p class="text-sm text-stone-500 mt-0.5">Side-by-side metrics across all departments</p>
</div>

<% if @comparison.empty? %>
  <div class="bg-white rounded-xl border border-stone-200 p-12 text-center shadow-sm">
    <div class="w-14 h-14 rounded-2xl bg-stone-50 flex items-center justify-center mx-auto mb-4">
      <svg class="w-7 h-7 text-stone-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    </div>
    <p class="text-sm text-stone-500 max-w-xs mx-auto">No departments to compare yet. Upload datasets and link them to a department.</p>
    <%= link_to "Upload a dataset", new_dataset_path, class: "inline-flex items-center gap-2 mt-5 px-4 py-2.5 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors shadow-sm" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-5">
    <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-stone-800">Engagement score</h2>
      </div>
      <div class="px-6 py-5" data-controller="bar-chart"
           data-bar-chart-data-value="<%= @comparison.map { |r| { range: r[:name], count: r[:engagement]&.round(2) || 0 } }.to_json %>"
           data-bar-chart-orientation-value="horizontal">
        <canvas height="<%= [@comparison.size * 44, 140].max %>" class="w-full"></canvas>
      </div>
    </section>

    <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-stone-800">Turnover rate (%)</h2>
      </div>
      <div class="px-6 py-5" data-controller="bar-chart"
           data-bar-chart-data-value="<%= @comparison.map { |r| { range: r[:name], count: ((r[:turnover_rate] || 0) * 100).round(1) } }.to_json %>"
           data-bar-chart-orientation-value="horizontal">
        <canvas height="<%= [@comparison.size * 44, 140].max %>" class="w-full"></canvas>
      </div>
    </section>

    <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-stone-800">Event attendance (%)</h2>
      </div>
      <div class="px-6 py-5" data-controller="bar-chart"
           data-bar-chart-data-value="<%= @comparison.map { |r| { range: r[:name], count: ((r[:attendance_rate] || 0) * 100).round(1) } }.to_json %>"
           data-bar-chart-orientation-value="horizontal">
        <canvas height="<%= [@comparison.size * 44, 140].max %>" class="w-full"></canvas>
      </div>
    </section>

    <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
      <div class="px-6 py-4 border-b border-stone-100">
        <h2 class="text-sm font-semibold text-stone-800">Headcount</h2>
      </div>
      <div class="px-6 py-5" data-controller="bar-chart"
           data-bar-chart-data-value="<%= @comparison.map { |r| { range: r[:name], count: r[:headcount] || 0 } }.to_json %>"
           data-bar-chart-orientation-value="horizontal">
        <canvas height="<%= [@comparison.size * 44, 140].max %>" class="w-full"></canvas>
      </div>
    </section>
  </div>
<% end %>
