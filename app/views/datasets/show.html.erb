<div class="flex items-start justify-between mb-6">
  <div>
    <div class="flex items-center gap-1.5 text-xs text-stone-400 mb-2">
      <%= link_to "Datasets", datasets_path, class: "hover:text-stone-700 transition-colors" %>
      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
      <span class="text-stone-600 truncate max-w-xs"><%= @dataset.original_filename %></span>
    </div>
    <h1 class="text-xl font-bold text-stone-900 flex items-center gap-2.5">
      <%= @dataset.name %>
      <span class="<%= status_pill_classes(@dataset.status) %>"><%= @dataset.status %></span>
    </h1>
    <div class="text-sm text-stone-400 mt-1 flex items-center gap-2 flex-wrap">
      <%= dataset_type_badge(@dataset.dataset_type) %>
      <% if @dataset.department %>
        <span>·</span>
        <%= link_to @dataset.department.name, department_path(@dataset.department), class: "text-stone-600 hover:text-indigo-600 transition-colors" %>
      <% end %>
      <span>·</span><span><%= number_with_delimiter(@dataset.row_count) %> rows</span>
      <span>·</span><span><%= @dataset.dataset_columns.size %> columns</span>
    </div>
  </div>

  <div class="flex items-center gap-2 flex-wrap">
    <%= link_to export_dataset_path(@dataset), class: "inline-flex items-center gap-1.5 px-3 py-2 rounded-lg border border-stone-200 bg-white hover:bg-stone-50 text-sm text-stone-700 font-medium transition-colors shadow-sm" do %>
      <svg class="w-3.5 h-3.5 text-stone-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M9 19l3 3m0 0l3-3m-3 3V10"/></svg>
      Export CSV
    <% end %>
    <% unless @dataset.department %>
      <%= form_with url: assign_department_dataset_path(@dataset), method: :post, class: "inline-flex items-center gap-1.5" do |f| %>
        <%= text_field_tag :department_name, "", placeholder: "Link to department…", class: "px-3 py-2 text-sm border border-stone-300 rounded-lg w-44 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
        <%= submit_tag "Link", class: "px-3 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-medium transition-colors shadow-sm cursor-pointer" %>
      <% end %>
    <% end %>
  </div>
</div>

<% if @log %>
  <section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden mb-6">
    <div class="px-6 py-4 border-b border-stone-100">
      <h2 class="text-sm font-semibold text-stone-800">Import summary</h2>
    </div>
    <div class="grid grid-cols-3 divide-x divide-stone-100">
      <div class="px-6 py-5">
        <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-1">Imported</div>
        <div class="text-3xl font-bold tabular-nums text-emerald-700"><%= @log.imported_count %></div>
      </div>
      <div class="px-6 py-5">
        <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-1">Skipped</div>
        <div class="text-3xl font-bold tabular-nums text-stone-500"><%= @log.skipped_count %></div>
      </div>
      <div class="px-6 py-5">
        <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-1">Cleaning changes</div>
        <div class="text-3xl font-bold tabular-nums text-stone-900"><%= @log.cleaning_change_count %></div>
      </div>
    </div>

    <% if @log.cleaning_diff.any? %>
      <div class="px-6 py-4 border-t border-stone-100 bg-stone-50/50">
        <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-3">Cleaning pipeline</div>
        <ul class="space-y-2">
          <% @log.cleaning_diff.each do |entry| %>
            <li class="flex items-center gap-3 text-sm">
              <span class="w-6 h-6 rounded-full bg-indigo-50 text-indigo-600 text-[11px] font-bold flex items-center justify-center shrink-0 tabular-nums"><%= entry["count"] %></span>
              <span class="text-stone-700"><%= entry["description"] %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <% if @log.warnings.any? %>
      <div class="px-6 py-4 border-t border-stone-100">
        <div class="text-[11px] uppercase tracking-widest font-semibold text-stone-400 mb-3">Warnings</div>
        <ul class="space-y-2 text-sm">
          <% @log.warnings.each do |w| %>
            <li class="flex items-start gap-2">
              <svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
              <span class="text-stone-700">
                <% case w["kind"] %>
                <% when "missing_values" %>
                  Missing values: <strong><%= w["count"] %></strong> in <span class="font-medium text-stone-900"><%= w["column"] %></span>
                <% when "duplicate_ids" %>
                  <span class="text-amber-700 font-medium">Duplicate IDs:</span> <%= w["count"] %> found in <%= w["column"] %>
                  <span class="text-stone-400 text-xs">(<%= w["values"].first(5).join(", ") %><%= "…" if w["values"].size > 5 %>)</span>
                <% when "blank_header" %>
                  <span class="text-amber-700 font-medium">Blank header:</span> <%= w["message"] %>
                <% else %>
                  <%= w["message"] || w["kind"] %>
                <% end %>
              </span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </section>
<% end %>

<section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden mb-6">
  <div class="px-6 py-4 border-b border-stone-100">
    <h2 class="text-sm font-semibold text-stone-800">Column profiles</h2>
  </div>
  <div class="divide-y divide-stone-50">
    <% @columns.each do |col| %>
      <%= render "column_stats", column: col %>
    <% end %>
  </div>
</section>

<section class="bg-white border border-stone-200 rounded-xl shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-stone-100 flex items-center justify-between">
    <h2 class="text-sm font-semibold text-stone-800">Data preview</h2>
    <span class="text-xs text-stone-400">First <%= @rows_preview.size %> of <%= number_with_delimiter(@dataset.row_count) %> rows</span>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="text-[11px] uppercase tracking-wider text-stone-400 bg-stone-50 border-b border-stone-100">
          <% @columns.each do |col| %>
            <th class="text-left px-5 py-3 font-semibold whitespace-nowrap"><%= col.name %></th>
          <% end %>
        </tr>
      </thead>
      <tbody class="divide-y divide-stone-50">
        <% @rows_preview.each do |row| %>
          <tr class="<%= row.flags['flagged'] ? 'bg-amber-50/50' : 'hover:bg-stone-50/60' %> transition-colors">
            <% @columns.each do |col| %>
              <td class="px-5 py-2.5 text-stone-700 whitespace-nowrap"><%= row.data[col.name] || content_tag(:span, "—", class: "text-stone-300") %></td>
            <% end %>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
